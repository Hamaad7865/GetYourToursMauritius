# Server-only secrets for `wrangler pages dev` (the local Cloudflare edge runtime).
# Copy to `.dev.vars`. These mirror the SERVER-ONLY values from `.env.local`.
# `next dev` reads `.env.local`; `wrangler pages dev` reads `.dev.vars` — keep both.

NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SUPABASE-SERVICE-ROLE-KEY"
SUPABASE_JWT_SECRET="YOUR-SUPABASE-JWT-SECRET"
# Canonical public origin, used for absolute URLs, sitemap, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Shared secret guarding the internal worker endpoints (/api/v1/internal/...); 503 until set. Must
# match the value the cron worker sends. Generate with `openssl rand -hex 32`. SERVER ONLY.
INTERNAL_TASK_SECRET="YOUR-LONG-RANDOM-SECRET"
AI_PROVIDER="google"
GOOGLE_GENERATIVE_AI_API_KEY="YOUR-GEMINI-API-KEY"
PEACH_CLIENT_ID="YOUR-PEACH-CLIENT-ID"
PEACH_CLIENT_SECRET="YOUR-PEACH-CLIENT-SECRET"
PEACH_MERCHANT_ID="YOUR-PEACH-MERCHANT-ID"
PEACH_ENTITY_ID="YOUR-PEACH-ENTITY-ID"
PEACH_WEBHOOK_SECRET="YOUR-PEACH-WEBHOOK-SECRET"
PEACH_AUTH_BASE_URL="https://sandbox-auth.peachpayments.com"
PEACH_CHECKOUT_BASE_URL="https://testsecure.peachpayments.com"
# PEACH_WEBHOOK_URL="https://your-tunnel.trycloudflare.com/api/v1/webhooks/payments"
PEACH_ENVIRONMENT="test"
