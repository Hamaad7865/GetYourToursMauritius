# =============================================================================
# Belle Mare Tours — environment variables
# Copy to `.env.local` for `next dev`, and mirror the SERVER-ONLY values into
# `.dev.vars` for `wrangler pages dev` (edge runtime). NEVER commit real values.
#
# Public (shipped to the browser): NEXT_PUBLIC_* only.
# Everything else is server-only and must never reach client bundles.
# =============================================================================

# --- Site -------------------------------------------------------------------
# Canonical public origin, used for absolute URLs, sitemap, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Maps Embed API key. Enables the route-with-stops map on activity
# detail pages; without it a keyless region map is shown. (NEXT_PUBLIC = client-exposed.)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR-GOOGLE-MAPS-EMBED-API-KEY

# --- Supabase ---------------------------------------------------------------
# Project URL + anon (public) key — safe to expose to the browser.
# (These correspond to SUPABASE_URL / SUPABASE_ANON_KEY in the brief.)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# Service-role key — SERVER ONLY. Bypasses RLS. Used by the Peach webhook and
# trusted admin operations. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY

# Legacy HS256 (symmetric) JWT secret. Only needed if you re-enable HS256 below.
# Found in Supabase: Settings -> API -> JWT Settings -> JWT Secret. SERVER ONLY.
# PRODUCTION: leave this UNSET (the project signs ES256 via JWKS) so a leaked secret
# cannot be used to forge tokens.
# SUPABASE_JWT_SECRET=YOUR-SUPABASE-JWT-SECRET

# Accept legacy HS256 access tokens. Default (unset) = REJECT them — recommended for prod.
# Set to true ONLY during a key-rotation transition while old HS256 tokens are still valid.
# ACCEPT_LEGACY_HS256=false

# Server-only Google Maps key for the AI Road Trip Planner's server calls: Routes API (real drive
# times) AND Places API (New) (live place discovery in the browse drawer + co-pilot). Falls back to
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY, but that public key is usually HTTP-referrer restricted and will
# 403 on server-side calls — so set a SEPARATE server key here (no referrer restriction; enable
# "Routes API" + "Places API (New)" on it). Without a working key the drawer/co-pilot can't list
# places (the map still works via the public key).
# GOOGLE_MAPS_API_KEY=YOUR-GOOGLE-MAPS-SERVER-API-KEY

# --- AI assistant -----------------------------------------------------------
# Provider is swappable. One of: google | workersai | anthropic | openai.
AI_PROVIDER=google
# Default free option (Google Gemini Flash). Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=YOUR-GEMINI-API-KEY
# Optional: override the Gemini model (default gemini-2.0-flash). Set this if Google retires a model.
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.0-flash
# Optional alternatives (only the selected provider's key is required):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Cloudflare Workers AI (when AI_PROVIDER=workersai):
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Peach Payments ---------------------------------------------------------
# SERVER ONLY. Peach Checkout (embedded widget) + webhook verification.
# Flow: OAuth (clientId+clientSecret+merchantId) -> POST {AUTH_BASE}/api/oauth/token -> Bearer token
#       -> POST {CHECKOUT_BASE}/v2/checkout -> checkoutId -> the browser mounts the widget.
# Settlement is confirmed ONLY by the HMAC-SHA256-signed webhook. Grab every value from the Peach
# sandbox Dashboard (Settings -> API keys). Without the full set the app uses an in-memory STUB
# provider (dev/CI only) whose webhook is unauthenticated; with PEACH_ENVIRONMENT=live (or a
# production-configured backend) the app REFUSES the stub (fail-closed).
PEACH_CLIENT_ID=YOUR-PEACH-CLIENT-ID
PEACH_CLIENT_SECRET=YOUR-PEACH-CLIENT-SECRET
PEACH_MERCHANT_ID=YOUR-PEACH-MERCHANT-ID
PEACH_ENTITY_ID=YOUR-PEACH-ENTITY-ID
PEACH_WEBHOOK_SECRET=YOUR-PEACH-WEBHOOK-SECRET
# Region-specific base URLs from your Dashboard's API/integration reference.
PEACH_AUTH_BASE_URL=https://sandbox-auth.peachpayments.com
PEACH_CHECKOUT_BASE_URL=https://testsecure.peachpayments.com
# The publicly-reachable webhook URL Peach signs over. For local sandbox testing set this to your
# tunnel, e.g. https://your-tunnel.trycloudflare.com/api/v1/webhooks/payments
# PEACH_WEBHOOK_URL=
# test | live  (live requires the full set above)
PEACH_ENVIRONMENT=test
# Go-live arming switch: 'true' makes /api/v1/health readiness REQUIRE live mode, so a production
# deploy still on sandbox credentials reports 503 instead of green. Leave unset until launch day;
# flip it in the SAME env change as the live Peach credentials.
# PEACH_EXPECT_LIVE=true

# --- Auth emails (Supabase Send-Email hook) ----------------------------------
# Bilingual branded auth emails (reset/confirm/magic-link): Supabase POSTs signed payloads to
# /api/v1/hooks/send-email and the app sends via Resend. The secret is shown when the hook is
# created (Supabase -> Authentication -> Hooks -> Send Email). Set the secret BEFORE enabling the
# hook or resets fail during the gap. See supabase/auth-email-templates/README.md.
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...
# AUTH_EMAIL_FROM=Belle Mare Tours <accounts@bellemaretours.com>

# --- Notifications (transactional email) ------------------------------------
# Resend (https://resend.com). Without BOTH, booking-confirmation emails are queued but the
# drain uses a no-op stub (nothing is sent). SERVER ONLY.
#
# TWO MAILBOXES, TWO JOBS — don't mix them up:
#   bookings@bellemaretours.com  OUTBOUND ONLY. The identity transactional mail is sent AS
#                                (confirmations, vouchers, invoices). Nobody reads this inbox.
#   info@bellemaretours.com      THE HUMAN INBOX. What customers see on the site (contact + legal
#                                pages), where owner alerts land, and the Reply-To on every mail we
#                                send — so a guest replying to their confirmation reaches a person.
#                                It lives in code as SITE.email (src/lib/seo/site.ts).
#
# RESEND_FROM must be a domain VERIFIED in Resend (SPF/DKIM DNS records added). See
# docs/domain-cutover-runbook.md — and note the one-SPF-record rule in there.
# RESEND_API_KEY=re_your_key
# RESEND_FROM=Belle Mare Tours <bookings@bellemaretours.com>

# Where owner alerts (new booking / refund needed) are emailed. Defaults to SITE.email (info@…)
# when unset, so this is optional. SERVER ONLY.
# OWNER_NOTIFY_EMAIL=info@bellemaretours.com

# Shared secret guarding the internal worker endpoints (/api/v1/internal/...). Use a long random
# value (e.g. `openssl rand -hex 32`). The endpoints are 503 until this is set. SERVER ONLY.
# INTERNAL_TASK_SECRET=your-long-random-secret

# --- Owner chat alerts (Telegram) --------------------------------------------
# New-booking/refund alerts land in a Telegram group. Bot token from @BotFather; chat id of the
# owner group (or a comma-separated list). SERVER ONLY.
# TELEGRAM_BOT_TOKEN=123456:bot-father-token
# TELEGRAM_OWNER_CHAT_ID=-1001234567890

# --- WhatsApp Cloud API (Meta) -----------------------------------------------
# SERVER ONLY. Two halves:
#
# 1) WEBHOOK (required to even register/connect a number in the Meta dashboard):
#    Callback URL  = https://bellemaretours.com/api/v1/webhooks/whatsapp
#    Verify token  = WHATSAPP_WEBHOOK_VERIFY_TOKEN — an arbitrary string YOU invent (long +
#                    random); paste the SAME value in the Meta dashboard and here.
#    App secret    = WHATSAPP_APP_SECRET (Meta app -> App settings -> Basic -> App secret);
#                    authenticates webhook POSTs (X-Hub-Signature-256).
#    Set BOTH here + redeploy BEFORE clicking "Verify and save" in Meta — the endpoint answers
#    503 until configured, so Meta's verification would fail during the gap. Inbound customer
#    messages are forwarded to the Telegram group above.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-long-random-verify-token
# WHATSAPP_APP_SECRET=your-meta-app-secret
#
# 2) SENDING (owner alerts over WhatsApp) — REQUIRED on a real deployment as of migration
#    20260817000000, which enqueues an owner alert on the whatsapp channel again on every
#    booking→confirmed and booking→refund_pending, alongside the Telegram + email copies.
#    Leave these unset and no alert is LOST (Telegram, email and the admin bell still fire), but
#    every booking burns 5 drain retries and parks a `failed` notification_outbox row — which
#    buries genuine failures. OWNER_WHATSAPP_TO fails loudly on EVERY runtime, dev included: the
#    drain resolves the 'owner' sentinel before it ever reaches the provider.
#    Permanent access token + business phone-number id + owner number in E.164 digits.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# OWNER_WHATSAPP_TO=23057729919
#
#    The template is REQUIRED too: a booking alert is always business-initiated, and Meta delivers
#    those outside an open 24-hour window only from an APPROVED template. Name + locale come from
#    WhatsApp Manager, and the locale must match exactly (`en` is rejected if approved as `en_US`).
#    Full walkthrough — number registration, system-user token, template, verification SQL:
#    docs/whatsapp-setup-runbook.md
# WHATSAPP_TEMPLATE_NAME=owner_booking_alert
# WHATSAPP_TEMPLATE_LANG=en

# --- Seed / import ----------------------------------------------------------
# Conversion rate used when normalising MUR transport prices to EUR in the seed
# script. TODO: confirm the real operator rate before go-live.
MUR_PER_EUR=50
