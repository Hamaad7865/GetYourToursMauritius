# =============================================================================
# GetYourToursMauritius — environment variables
# Copy to `.env.local` for `next dev`, and mirror the SERVER-ONLY values into
# `.dev.vars` for `wrangler pages dev` (edge runtime). NEVER commit real values.
#
# Public (shipped to the browser): NEXT_PUBLIC_* only.
# Everything else is server-only and must never reach client bundles.
# =============================================================================

# --- Site -------------------------------------------------------------------
# Canonical public origin, used for absolute URLs, sitemap, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Maps Embed API key. Enables the route-with-stops map on activity
# detail pages; without it a keyless region map is shown. (NEXT_PUBLIC = client-exposed.)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR-GOOGLE-MAPS-EMBED-API-KEY

# --- Supabase ---------------------------------------------------------------
# Project URL + anon (public) key — safe to expose to the browser.
# (These correspond to SUPABASE_URL / SUPABASE_ANON_KEY in the brief.)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# Service-role key — SERVER ONLY. Bypasses RLS. Used by the Peach webhook and
# trusted admin operations. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY

# Legacy HS256 (symmetric) JWT secret. Only needed if you re-enable HS256 below.
# Found in Supabase: Settings -> API -> JWT Settings -> JWT Secret. SERVER ONLY.
# PRODUCTION: leave this UNSET (the project signs ES256 via JWKS) so a leaked secret
# cannot be used to forge tokens.
# SUPABASE_JWT_SECRET=YOUR-SUPABASE-JWT-SECRET

# Accept legacy HS256 access tokens. Default (unset) = REJECT them — recommended for prod.
# Set to true ONLY during a key-rotation transition while old HS256 tokens are still valid.
# ACCEPT_LEGACY_HS256=false

# --- AI assistant -----------------------------------------------------------
# Provider is swappable. One of: google | workersai | anthropic | openai.
AI_PROVIDER=google
# Default free option (Google Gemini Flash).
GOOGLE_GENERATIVE_AI_API_KEY=YOUR-GEMINI-API-KEY
# Optional alternatives (only the selected provider's key is required):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Cloudflare Workers AI (when AI_PROVIDER=workersai):
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Peach Payments ---------------------------------------------------------
# SERVER ONLY. Hosted checkout + webhook verification.
# Without all three keys the app uses an in-memory STUB provider (dev/CI only) whose
# webhook is unauthenticated. With PEACH_ENVIRONMENT=live the app REFUSES to start the
# stub: the three keys below become mandatory (fail-closed) so a misconfigured production
# deploy can never expose a free-booking webhook.
PEACH_ENTITY_ID=YOUR-PEACH-ENTITY-ID
PEACH_ACCESS_TOKEN=YOUR-PEACH-ACCESS-TOKEN
PEACH_WEBHOOK_SECRET=YOUR-PEACH-WEBHOOK-SECRET
# test | live  (live requires the three keys above)
PEACH_ENVIRONMENT=test

# --- Seed / import ----------------------------------------------------------
# Conversion rate used when normalising MUR transport prices to EUR in the seed
# script. TODO: confirm the real operator rate before go-live.
MUR_PER_EUR=50
