# @cloudflare/next-on-pages (deprecated) caps its peer dependency at next <=15.5.2,
# but we keep Next on the latest patched 15.5.x for security. The two coexist fine;
# this lets npm install new packages without tripping over that over-conservative
# peer range. Revisit when we migrate off next-on-pages (-> OpenNext).
legacy-peer-deps=true
